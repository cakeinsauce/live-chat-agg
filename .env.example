TWITCH_CHANNEL=your_twitch_channel
TIKTOK_USERNAME=@your_tiktok_handle

# --- Optional: reading works anonymously, the rest is only for extra features ---

# EulerStream key for higher TikTok signing rate limits:
SIGN_API_KEY=

# Send to Twitch chat (both required). OAuth token needs the chat:edit scope:
TWITCH_OAUTH_TOKEN=
TWITCH_BOT_USERNAME=

# Live Twitch viewer/sub counts via Helix (create an app at dev.twitch.tv):
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Send to TikTok chat. WARNING: TIKTOK_SESSIONID is your session cookie and
# grants FULL access to your TikTok account. Keep it local; never share it.
TIKTOK_SESSIONID=
TIKTOK_TARGET_IDC=

# Text-to-speech: reads the chat message text aloud in Russian (never the
# nickname). Two engines:
#   browser - uses the operating-system voices in the overlay's browser
#             (macOS: Milena; Windows: Microsoft Irina/Pavel). Offline, instant.
#   neural  - uses edge-tts (Microsoft online neural voices). Much more natural,
#             needs an internet connection, ~2-3s latency.
TTS_ENABLED=false
TTS_ENGINE=browser
# Browser voice name (leave blank to auto-pick the first Russian voice):
TTS_VOICE=
# Neural (edge-tts) voice. Good Russian options: ru-RU-SvetlanaNeural (female),
# ru-RU-DmitryNeural (male):
TTS_NEURAL_VOICE=ru-RU-SvetlanaNeural
# When the neural engine fails (e.g. offline), fall back to a browser voice:
TTS_FALLBACK_TO_BROWSER=false
# Tip: when both an operator window and an OBS browser source are open, add
# ?mute_tts=1 to the OBS source URL so only one window speaks.

# Demo/test messages. When ON and no stream is connected, the app emits fake
# chat lines so you can style the overlay before going live. OFF by default.
# You can also inject one-off test lines from the composer's "Test" button.
ENABLE_TEST_MESSAGES=false

# Quick-reply phrases for the composer (JSON array):
TEMPLATES=[]

HOST=0.0.0.0
PORT=8000
RING_BUFFER_SIZE=50
