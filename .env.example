TWITCH_CHANNEL=your_twitch_channel
TIKTOK_USERNAME=@your_tiktok_handle

# --- Optional: reading works anonymously, the rest is only for extra features ---

# EulerStream key for higher TikTok signing rate limits:
SIGN_API_KEY=

# Send to Twitch chat (both required). OAuth token needs the chat:edit scope:
TWITCH_OAUTH_TOKEN=
TWITCH_BOT_USERNAME=

# Live Twitch viewer/sub counts via Helix (create an app at dev.twitch.tv):
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Send to TikTok chat. WARNING: TIKTOK_SESSIONID is your session cookie and
# grants FULL access to your TikTok account. Keep it local; never share it.
TIKTOK_SESSIONID=
TIKTOK_TARGET_IDC=

# Text-to-speech (reads chat aloud in Russian):
TTS_ENABLED=false
TTS_VOICE=

# Quick-reply phrases for the composer (JSON array):
TEMPLATES=[]

HOST=0.0.0.0
PORT=8000
RING_BUFFER_SIZE=50
